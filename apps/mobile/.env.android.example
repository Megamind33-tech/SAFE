# SAFE mobile — Android device test build template
# Copy to apps/mobile/.env before: npm run build && npm run android:sync
# Do NOT commit filled secrets. Do NOT use localhost on a physical device.

# Staging API (recommended) or LAN IP reachable from phone, e.g. http://192.168.1.50:8080
VITE_API_BASE_URL="https://staging-api.safe.co.zm"

# Must be false for Android test / staging / production builds
VITE_CLAIMS_QA_CAPTURE=false
VITE_QR_QA_CAPTURE=false
