# SAFE mobile — STAGING build template
# Copy to apps/mobile/.env before npm run build:mobile
# Do NOT commit filled secrets or production URLs to git.

VITE_API_BASE_URL="https://api.staging.example"

# Optional: enables the premium TomTom street map and real traffic layer.
# Before release, restrict this key to approved SAFE web origins.
VITE_TOMTOM_API_KEY=""

# Must be false on staging/production builds
VITE_CLAIMS_QA_CAPTURE=false
VITE_QR_QA_CAPTURE=false
