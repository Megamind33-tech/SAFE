<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG-only network security policy for SAFE Android.

  Allows cleartext HTTP so developers can point VITE_API_BASE_URL at a LAN IP
  (e.g. http://192.168.x.x:8080) for real-device testing against a local backend.

  Release builds continue to use the stricter config in src/main/.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
