# SAFE backend — STAGING template
# Copy values to your platform secrets manager. Do NOT commit filled secrets.

SAFE_APP_ENV=staging

# Database — use persistent path on staging host
DATABASE_URL="file:/var/safe/staging.db"
PORT=8080

# Generate a long random string (not dev-secret-change-me)
JWT_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET"

# Comma-separated staging frontend origins (HTTPS)
CORS_ORIGINS="https://app.staging.example,https://admin.staging.example"

# Public mobile URL for QR payloads (no trailing slash)
SAFE_QR_PUBLIC_BASE_URL="https://app.staging.example"

# Support & legal (recommended for realistic mobile Settings/Help)
SAFE_SUPPORT_PHONE="+260XXXXXXXXX"
SAFE_SUPPORT_EMAIL="support@staging.example"
SAFE_TERMS_URL="https://staging.example/terms"
SAFE_PRIVACY_URL="https://staging.example/privacy"
SAFE_CLAIMS_POLICY_URL="https://staging.example/claims-policy"

# Payment — choose one policy:
# A) No gateway yet (staging simulate):
SAFE_PAYMENT_GATEWAY_ENABLED=false
SAFE_PAYMENT_SIMULATE_SUCCESS=true
# B) Gateway wired:
# SAFE_PAYMENT_GATEWAY_ENABLED=true
# SAFE_PAYMENT_SIMULATE_SUCCESS=false

SAFE_CARD_PAYMENTS_ENABLED=false

# Claims upload — keep false until blob storage wired
SAFE_CLAIMS_UPLOAD_ENABLED=false

# Notifications — keep false until providers wired
SAFE_NOTIFICATION_SMS_ENABLED=false
SAFE_NOTIFICATION_EMAIL_ENABLED=false

# Staging admin (inject via secrets manager; run create-staging-admin after migrate)
SAFE_ADMIN_EMAIL="ops-admin@staging.example"
SAFE_ADMIN_PASSWORD="REPLACE_WITH_STRONG_PASSWORD_MIN_10_CHARS"
SAFE_DISABLE_DEFAULT_ADMIN=true

# Staging safety
SAFE_ALLOW_DEV_VEHICLE_AUTO_CREATE=false
