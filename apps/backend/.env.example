## SQLite note:
## Some Windows setups require an absolute path for Prisma SQLite.
## Example: DATABASE_URL="file:C:/Users/<you>/path/to/apps/backend/dev.db"
DATABASE_URL="file:./dev.db"
PORT=8080
JWT_SECRET="dev-secret-change-me"
CORS_ORIGINS="http://127.0.0.1:5173,http://127.0.0.1:5174"
# Optional — Help & Safety support contacts (omit to show "not configured" in app)
# SAFE_SUPPORT_PHONE="+260211000000"
# SAFE_SUPPORT_EMAIL="support@safe.co.zm"
# SAFE_EMERGENCY_PHONE="999"
# SAFE_SUPPORT_HOURS="Mon–Fri 08:00–17:00 CAT"
# SAFE_CLAIMS_GUIDE_VERSION="1"
# Optional — Notifications channel toggles (SMS/email UI disabled unless true)
# SAFE_NOTIFICATION_SMS_ENABLED=false
# SAFE_NOTIFICATION_EMAIL_ENABLED=false
