## SQLite note:
## Some Windows setups require an absolute path for Prisma SQLite.
DATABASE_URL="file:./dev.db"
PORT=8080
JWT_SECRET="dev-secret-change-me"
CORS_ORIGINS="http://127.0.0.1:5173,http://127.0.0.1:5174"

# App environment: local | staging | production
# SAFE_APP_ENV=local

# Legal & support (optional — omit to show "not configured" in mobile)
# SAFE_TERMS_URL=
# SAFE_PRIVACY_URL=
# SAFE_CLAIMS_POLICY_URL=
# SAFE_SUPPORT_PHONE=
# SAFE_SUPPORT_EMAIL=
# SAFE_EMERGENCY_PHONE=
# SAFE_SUPPORT_HOURS=

# Notifications (disabled until providers wired)
# SAFE_NOTIFICATION_SMS_ENABLED=false
# SAFE_NOTIFICATION_EMAIL_ENABLED=false

# Payment (required for real cover activation in production)
# SAFE_PAYMENT_GATEWAY_ENABLED=true
# SAFE_PAYMENT_SIMULATE_SUCCESS=false
# SAFE_CARD_PAYMENTS_ENABLED=false

# Cover behavior
# SAFE_ALLOW_COVER_STACKING=false
# SAFE_ALLOW_COVER_EXTENSION=false

# Claims
# SAFE_CLAIMS_UPLOAD_ENABLED=false
# SAFE_CLAIM_WINDOW_HOURS=168

# Account features
# SAFE_DATA_EXPORT_ENABLED=false
# SAFE_ACCOUNT_DELETION_ENABLED=false

# QR public URL encoded in vehicle QR payloads
# SAFE_QR_PUBLIC_BASE_URL=https://safe.co.zm

# Dev-only: auto-create vehicles on verify when not found (disabled in production)
# SAFE_ALLOW_DEV_VEHICLE_AUTO_CREATE=true

# Staging admin (run create-staging-admin on staging DB only — never commit real secrets)
# SAFE_ADMIN_EMAIL=ops-admin@staging.example
# SAFE_ADMIN_PASSWORD=
# SAFE_DISABLE_DEFAULT_ADMIN=true

# QA dashboard staff accounts (local dev only — never in production)
# SAFE_SEED_DASHBOARD_STAFF=true

# QA capture scripts (local dev only — never in production)
# SAFE_CLAIMS_UPLOAD_ENABLED=false
# SAFE_PAYMENT_GATEWAY_ENABLED=true
